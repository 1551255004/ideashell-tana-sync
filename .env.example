# ideaShell MCP
IDEASHELL_TOKEN=replace-with-your-ideashell-api-key
IDEASHELL_MCP_ENDPOINT=https://api.ideashell.cn/ideashell/mcp

# Tana Write API
TANA_TOKEN=replace-with-your-tana-write-api-token
# Use INBOX, or replace with the node ID of a node you created in Tana.
TANA_TARGET_NODE_ID=INBOX

# Optional AI polish. Set to 0 to write the original note text.
OPENAI_POLISH_ENABLED=0
AI_PROVIDER=openai-compatible
AI_SERVICE_PRESET=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5-mini
AI_API_KEY=replace-with-your-ai-api-key
# Legacy names remain supported for existing installations.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-with-your-openai-compatible-api-key
POLISH_PROMPT_FILE=polish-prompt.md

# Mark ideaShell notes after a successful Tana write.
IDEASHELL_MARK_TRANSFERRED=1
IDEASHELL_TRANSFERRED_PREFIX=～～
AUTOMATIC_SYNC_INTERVAL_MINUTES=5
DAILY_SYNC_HOUR=9
DAILY_SYNC_MINUTE=0
